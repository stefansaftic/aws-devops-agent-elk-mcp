# ============================================
# ELK MCP Server for AWS DevOps Agent
# Environment Configuration
# ============================================

# OAuth 2.0 Client Credentials (used by AWS DevOps Agent to authenticate)
OAUTH_CLIENT_ID=devops-agent
OAUTH_CLIENT_SECRET=demo-secret-change-me

# JWT Configuration
JWT_SECRET=jwt-secret-change-me-in-production
TOKEN_EXPIRY_SECONDS=3600

# OAuth Issuer/Audience (for JWT validation)
OAUTH_ISSUER=elk-mcp-server
OAUTH_AUDIENCE=elk-mcp

# Elasticsearch Security
# Password for the built-in 'elastic' superuser (used to bootstrap API keys on startup)
ELASTIC_PASSWORD=changeme

# ─── External Elasticsearch (optional) ───────────────────────────────────────
# To connect to an external Elasticsearch cluster instead of the bundled one,
# set ES_URL and one of the auth options below, then remove the 'elasticsearch'
# and 'es-setup' services from docker-compose.yml.
#
# ES_URL=https://your-cluster.es.io:9200
# ES_API_KEY=your-base64-encoded-api-key
#
# Or username/password:
# ES_USERNAME=elastic
# ES_PASSWORD=your-password
# ES_SSL_SKIP_VERIFY=false
